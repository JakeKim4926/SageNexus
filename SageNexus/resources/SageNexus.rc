#pragma code_page(65001)
#include "resource.h"

IDI_APP_ICON ICON "app.ico"

IDD_LOGIN DIALOGEX 0, 0, 220, 90
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "SageNexus"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "비밀번호를 입력해주세요", IDC_STATIC, 12, 12, 196, 10
    LTEXT           "비밀번호", IDC_STATIC, 12, 34, 48, 10
    EDITTEXT        IDC_EDIT_PASSWORD, 64, 32, 144, 14, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT           "", IDC_STATIC_ERROR, 12, 52, 196, 10
    DEFPUSHBUTTON   "확인", IDOK, 108, 70, 48, 14
    PUSHBUTTON      "취소", IDCANCEL, 162, 70, 48, 14
END

IDD_SET_PASSWORD DIALOGEX 0, 0, 220, 110
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "SageNexus 초기 설정"
FONT 9, "Segoe UI"
BEGIN
    LTEXT           "관리자 비밀번호를 설정해주세요", IDC_STATIC, 12, 12, 196, 10
    LTEXT           "비밀번호", IDC_STATIC, 12, 34, 48, 10
    EDITTEXT        IDC_EDIT_PASSWORD, 64, 32, 144, 14, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT           "비밀번호 확인", IDC_STATIC, 12, 54, 48, 10
    EDITTEXT        IDC_EDIT_CONFIRM, 64, 52, 144, 14, ES_PASSWORD | ES_AUTOHSCROLL
    LTEXT           "", IDC_STATIC_ERROR, 12, 72, 196, 10
    DEFPUSHBUTTON   "설정", IDOK, 162, 90, 48, 14
END
